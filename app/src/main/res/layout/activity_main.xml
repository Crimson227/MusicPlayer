<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/library_bg"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/libraryScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="106dp">

        <LinearLayout
            android:id="@+id/contentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="116dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/pageTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0"
                    android:text="资料库"
                    android:textColor="@color/library_text"
                    android:textSize="40sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/deletePlaylistButton"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_icon_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="..."
                    android:textColor="@color/fresh_red"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/createPlaylistButton"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/bg_icon_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/fresh_red"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/libraryMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/sectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:text="最近添加"
                android:textColor="@color/library_text"
                android:textSize="29sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/songList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/miniPlayer"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="94dp"
        android:background="@drawable/bg_mini_player"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:id="@+id/miniCover"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_album_pink"
            android:padding="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/miniTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="选择一首歌曲"
                android:textColor="@color/library_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/miniSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="导入后即可播放"
                android:textColor="@color/library_subtext"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/miniPlayButton"
            style="@style/Widget.Music.TransparentIcon"
            android:contentDescription="播放或暂停"
            android:src="@drawable/ic_play_dark" />

        <ImageButton
            android:id="@+id/miniNextButton"
            style="@style/Widget.Music.TransparentIcon"
            android:layout_marginStart="8dp"
            android:contentDescription="下一首"
            android:src="@drawable/ic_next_dark" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/tabLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tabLibraryIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♫"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabLibraryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="资料库"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tabSearchIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabSearchLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="搜索"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabLikes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tabLikesIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♡"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabLikesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="喜欢"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabMine"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tabMineIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabMineLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="设置"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/playerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_player_gradient"
        android:visibility="gone">

        <ImageView
            android:id="@+id/backgroundImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.22"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/playerTint"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#663A3238" />

        <LinearLayout
            android:id="@+id/playerContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="28dp"
            android:paddingEnd="32dp"
            android:paddingBottom="30dp">

            <View
                android:id="@+id/collapseHandle"
                android:layout_width="78dp"
                android:layout_height="6dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_player_handle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/playerCover"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_album_pink"
                    android:padding="18dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/songTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="未选择歌曲"
                        android:textColor="@color/player_text"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/songMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                android:text="通过菜单导入音乐"
                        android:textColor="@color/player_subtext"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/favoriteButton"
                    style="@style/Widget.Music.PlayerRoundIcon"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="加入喜欢"
                    android:src="@drawable/ic_heart_outline" />

                <ImageButton
                    android:id="@+id/importButton"
                    style="@style/Widget.Music.PlayerRoundIcon"
                    android:contentDescription="更多"
                    android:src="@drawable/ic_more" />
            </LinearLayout>

            <TextView
                android:id="@+id/lyricsView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="78dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:lineSpacingExtra="12dp"
                android:text="暂无歌词\n\n可在菜单中关联歌词"
                android:textColor="@color/player_lyric"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="已暂停"
                android:textColor="@color/player_subtext"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/progressSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:progressTint="@color/player_text"
                android:thumbTint="@android:color/transparent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/currentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textColor="@color/player_subtext"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/totalTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="-00:00"
                    android:textColor="@color/player_subtext"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/previousButton"
                    style="@style/Widget.Music.PlayerBigIcon"
                    android:contentDescription="上一首"
                    android:src="@drawable/ic_previous" />

                <ImageButton
                    android:id="@+id/playPauseButton"
                    style="@style/Widget.Music.PlayerMainIcon"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:contentDescription="播放或暂停"
                    android:src="@drawable/ic_play" />

                <ImageButton
                    android:id="@+id/nextButton"
                    style="@style/Widget.Music.PlayerBigIcon"
                    android:contentDescription="下一首"
                    android:src="@drawable/ic_next" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_volume_low" />

                <SeekBar
                    android:id="@+id/volumeSeek"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="70"
                    android:progressTint="@color/player_text"
                    android:thumbTint="@android:color/transparent" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_volume_high" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:gravity="center"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1">

                    <ImageButton
                        android:id="@+id/modeButton"
                        style="@style/Widget.Music.PlayerRoundIcon"
                        android:layout_gravity="center"
                        android:contentDescription="播放模式"
                        android:src="@drawable/ic_mode_repeat" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1">

                    <ImageButton
                        android:id="@+id/stopButton"
                        style="@style/Widget.Music.PlayerRoundIcon"
                        android:layout_gravity="center"
                        android:contentDescription="停止"
                        android:src="@drawable/ic_stop_centered" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_weight="1">

                    <ImageButton
                        android:id="@+id/showLibraryButton"
                        style="@style/Widget.Music.PlayerRoundIcon"
                        android:layout_gravity="center"
                        android:contentDescription="返回列表"
                        android:src="@drawable/ic_list" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
